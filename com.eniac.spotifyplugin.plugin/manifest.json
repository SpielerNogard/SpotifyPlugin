{
    "name": "SpotifyPlugin",
    "uuid": "com.eniac.spotifyplugin",
    "version": "1.1.0",
    "author": "ENIAC",
    "entry": "backend/plugin.cjs",
    "description": "Spotify integration for Flexbar",
    "repo": "https://github.com/ENIAC-Tech/SpotifyPlugin",
    "sdk": {
        "version": "1.0.0"
    },
    "software": {
        "minimumVersion": "1.0.0"
    },
    "os": [
        {
            "platform": "mac",
            "minimumVersion": "10.15"
        },
        {
            "platform": "windows",
            "minimumVersion": "10"
        }
    ],
    "device": [
        {
            "name": "flexbar",
            "version": "1.0.0"
        }
    ],
    "configPage": "configPage",
    "keyLibrary": {
        "title": "$PluginName",
        "style": {
            "icon": "mdi mdi-spotify"
        },
        "children": [
          {
                "title": "$NowPlaying.Title",
                "tip": "$NowPlaying.Tip",
                "cid": "com.eniac.spotifyplugin.nowplaying",
                "config": {
                    "keyType": "default",
                    "clickable": false,
                    "platform": ["windows", "mac"]
                },
                "style": {
                    "icon": "mdi mdi-music",
                    "width": 600,
                    "flags": ["disable-bg", "disable-fg", "disable-icon-sel", "disable-layout-sel"]
                },
                "data": {
                    "showTitle": true,
                    "showArtist": true,
                    "showAlbum": true,
                    "showProgress": true
                }
            },
            {
                "title": "$Like.Title",
                "tip": "$Like.Tip",
                "cid": "com.eniac.spotifyplugin.like",
                "config": {
                    "keyType": "multiState",
                    "platform": ["windows", "mac"]
                },
                "style": {
                    "icon": "mdi mdi-heart-outline",
                    "width": 240,
                    "multiStyle": [
                        {
                            "icon": "mdi mdi-heart-outline",
                            "fgColor": "#FFFFFF"
                        },
                        {
                            "icon": "mdi mdi-heart",
                            "fgColor": "#1DB954"
                        }
                    ]
                },
                "data": {}
            },
            {
                "title": "$Shuffle.Title",
                "tip": "$Shuffle.Tip",
                "cid": "com.eniac.spotifyplugin.shuffle",
                "config": {
                    "keyType": "multiState",
                    "platform": ["windows", "mac"]
                },
                "style": {
                    "icon": "mdi mdi-shuffle",
                    "width": 240,
                    "multiStyle": [
                        {
                            "icon": "mdi mdi-shuffle",
                            "fgColor": "#FFFFFF"
                        },
                        {
                            "icon": "mdi mdi-shuffle",
                            "fgColor": "#1DB954"
                        }
                    ]
                },
                "data": {}
            },
            {
                "title": "$Repeat.Title",
                "tip": "$Repeat.Tip",
                "cid": "com.eniac.spotifyplugin.repeat",
                "config": {
                    "keyType": "multiState",
                    "platform": ["windows", "mac"]
                },
                "style": {
                    "icon": "mdi mdi-repeat",
                    "width": 240,
                    "multiStyle": [
                        {
                            "icon": "mdi mdi-repeat",
                            "fgColor": "#FFFFFF"
                        },
                        {
                            "icon": "mdi mdi-repeat",
                            "fgColor": "#1DB954"
                        },
                        {
                            "icon": "mdi mdi-repeat-once",
                            "fgColor": "#1DB954"
                        }
                    ]
                },
                "data": {}
            },
            {
                "title": "$Previous.Title",
                "tip": "$Previous.Tip",
                "cid": "com.eniac.spotifyplugin.previous",
                "config": {
                    "keyType": "default",
                    "clickable": true,
                    "platform": ["windows", "mac"]
                },
                "style": {
                    "icon": "mdi mdi-skip-previous",
                    "width": 240
                },
                "data": {}
            },
            {
                "title": "$Next.Title",
                "tip": "$Next.Tip",
                "cid": "com.eniac.spotifyplugin.next",
              "config": {
                  "keyType": "default",
                  "clickable": true,
                    "platform": ["windows", "mac"]
              },
              "style": {
                    "icon": "mdi mdi-skip-next",
                  "width": 240
              },
                "data": {}
            },
            {
                "title": "$PlayPause.Title",
                "tip": "$PlayPause.Tip",
                "cid": "com.eniac.spotifyplugin.playpause",
                "config": {
                    "keyType": "multiState",
                    "platform": ["windows", "mac"]
                },
                "style": {
                    "icon": "mdi mdi-play",
                    "width": 240,
                    "multiStyle": [
                        {
                            "icon": "mdi mdi-play",
                            "fgColor": "#FFFFFF"
                        },
                        {
                            "icon": "mdi mdi-pause",
                            "fgColor": "#1DB954"
              }
                    ]
                },
                "data": {}
          }
        ]
    },
